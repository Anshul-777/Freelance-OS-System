# FreelanceOS Backend Environment Variables
# Copy to .env and fill in your values. Do NOT commit .env to git!

# Database (Required for production)
DATABASE_URL=postgresql://username:password@host:5432/freelanceos
# Example: postgresql://postgres:yourpass@db.freelanceos.neon.tech/freelanceos?sslmode=require
# Or Supabase: postgresql://postgres.[project-id].supabase.co:5432/postgres

# JWT Security (Required - generate strong secret)
SECRET_KEY=your-super-secret-jwt-key-here-use-openssl-rand-hex-32
# Generate: openssl rand -hex 32

# Frontend URL (Required for CORS and emails)
FRONTEND_URL=https://freelance-os-system.vercel.app

# Email (Optional - Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEFAULT_FROM_EMAIL=noreply@freelanceos.com

# Supabase Storage (Optional - file uploads)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App Settings
DEBUG=false
APP_NAME=FreelanceOS
APP_VERSION=1.0.0

# Demo (Development only - disable in prod)
# DEMO_EMAIL=demo@freelanceos.com
# DEMO_PASSWORD=demo123
